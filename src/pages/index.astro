    .text-muted { color: var(--color-muted); }
    .text-accent { color: var(--color-accent); }
    .text-gold { color: var(--color-gold); }
    .text-success { color: var(--color-success); }
    .text-alert { color: var(--color-alert); }
    .text-border { color: var(--color-border); }

    .border-border { border-color: var(--color-border); }
    .border-accent { border-color: var(--color-accent); }
    .border-gold\/50 { border-color: rgb(212 160 23 / 0.5); }
    .border-accent\/50 { border-color: rgb(96 165 250 / 0.5); }

    /* Hover states */
    .hover\:border-accent:hover { border-color: var(--color-accent); }
    .hover\:border-gold\/50:hover { border-color: rgb(212 160 23 / 0.5); }
    .hover\:border-accent\/50:hover { border-color: rgb(96 165 250 / 0.5); }
    .hover\:text-accent:hover { color: var(--color-accent); }
    .hover\:text-accent\/80:hover { color: rgb(96 165 250 / 0.8); }
    .hover\:text-gold\/80:hover { color: rgb(212 160 23 / 0.8); }
    .hover\:text-primary:hover { color: var(--color-primary); }
    .hover\:bg-accent:hover { background-color: var(--color-accent); }
    .hover\:bg-accent\/90:hover { background-color: rgb(96 165 250 / 0.9); }
    .hover\:bg-accent\/20:hover { background-color: rgb(96 165 250 / 0.2); }

    .group-hover\:bg-accent\/10:hover { background-color: rgb(96 165 250 / 0.1); }
    .group:hover .group-hover\:bg-accent\/10 { background-color: rgb(96 165 250 / 0.1); }
    .group:hover .group-hover\:scale-105 { transform: scale(1.05); }

    /* Shadow utilities */
    .hover\:shadow-accent\/20:hover { --tw-shadow-color: rgb(96 165 250 / 0.2); }
    
    /* Background with alpha */
    .bg-base\/75 { background-color: rgb(10 14 26 / 0.75); }
    .bg-base\/80 { background-color: rgb(10 14 26 / 0.8); }
    .bg-surface-dark\/80 { background-color: rgb(15 29 61 / 0.8); }

    /* Typography */
    .font-display { font-family: 'Bebas Neue', 'Oswald', sans-serif; }
    .font-mono { font-family: 'JetBrains Mono', monospace; }
    body { font-family: 'Inter', sans-serif; }

    /* Radial gradient */
    .bg-gradient-radial {
      background: radial-gradient(circle at center, var(--tw-gradient-from), var(--tw-gradient-to));
    }
    .from-accent\/5 { --tw-gradient-from: rgb(96 165 250 / 0.05); }
    .to-transparent { --tw-gradient-to: transparent; }

    /* Animations */
    @keyframes ping {
      75%, 100% {
        transform: scale(2);
        opacity: 0;
      }
    }
    .animate-ping {
      animation: ping 1s cubic-bezier(0, 0, 0.2, 1) infinite;
    }

    @keyframes bounce {
      0%, 100% {
        transform: translateY(-25%);
        animation-timing-function: cubic-bezier(0.8, 0, 1, 1);
      }
      50% {
        transform: translateY(0);
        animation-timing-function: cubic-bezier(0, 0, 0.2, 1);
      }
    }
    .animate-bounce {
      animation: bounce 1s infinite;
    }

    /* Scroll smooth */
    .scroll-smooth {
      scroll-behavior: smooth;
    }

    /* Focus states for accessibility */
    a:focus-visible,
    button:focus-visible {
      outline: 2px solid var(--color-accent);
      outline-offset: 2px;
    }

    /* Selection */
    ::selection {
      background-color: var(--color-accent);
      color: var(--color-base);
    }

    /* Respect reduced motion preference */
    @media (prefers-reduced-motion: reduce) {
      #main-header {
        transition: none;
      }
      #main-header.nav-hidden {
        transform: none;
      }
    }
  </style>
</body>
</html>