---
// Granite Ridge County Sheriff's Office — Modern Transparency-Focused Homepage
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Granite Ridge County Sheriff's Office — A modern, data-driven sheriff department serving New Hampshire's North Country since 1847." />
  <title>Granite Ridge County Sheriff's Office | Protecting the North Country</title>
  
  <!-- Async Google Fonts Preload -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=optional" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=optional" media="print" onload="this.media='all'" />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" />
  </noscript>
</head>
<body class="bg-base text-primary antialiased">
  
  <!-- EMERGENCY BAR (scrolls away with page) -->
  <div class="relative z-50 bg-gradient-to-r from-alert via-orange-600 to-alert py-2 px-4 text-center" id="emergency-bar">
    <p class="text-sm md:text-base font-semibold text-white tracking-wide">
      <span aria-hidden="true">🚨</span> EMERGENCY: DIAL <a href="tel:911" class="underline underline-offset-2 hover:no-underline">911</a> — Non-Emergency: <a href="tel:6035552400" class="underline underline-offset-2 hover:no-underline">(603) 555-2400</a>
    </p>
  </div>

  <!-- NAVIGATION (auto-hides on scroll down, reveals on scroll up) -->
  <header id="main-header" class="sticky top-0 z-40 bg-base/80 backdrop-blur-xl border-b border-border/50 transition-transform duration-300 ease-in-out">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
      <!-- Logo Badge -->
      <a href="/" class="flex items-center gap-3 group" aria-label="Granite Ridge County Sheriff's Office Home">
        <svg class="w-12 h-12 text-gold transition-transform group-hover:scale-105" viewBox="0 0 80 80" fill="none" aria-hidden="true">
          <!-- Six-point sheriff star badge -->
          <polygon points="40,4 48,28 76,28 54,44 62,72 40,56 18,72 26,44 4,28 32,28" fill="currentColor" stroke="#0a0e1a" stroke-width="2"/>
          <circle cx="40" cy="40" r="16" fill="#0f1d3d" stroke="currentColor" stroke-width="2"/>
          <text x="40" y="44" text-anchor="middle" fill="currentColor" font-size="10" font-weight="bold" font-family="Inter, sans-serif">GRCSO</text>
        </svg>
        <div class="hidden sm:block">
          <p class="font-display text-xl text-primary leading-none">GRANITE RIDGE</p>
          <p class="text-xs text-muted tracking-widest">SHERIFF'S OFFICE</p>
        </div>
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden lg:flex items-center gap-8">
        <li><a href="#about" class="text-muted hover:text-primary transition-colors text-sm font-medium">About</a></li>
        <li><a href="#services" class="text-muted hover:text-primary transition-colors text-sm font-medium">Services</a></li>
        <li><a href="#transparency" class="text-muted hover:text-primary transition-colors text-sm font-medium">Transparency</a></li>
        <li><a href="#community" class="text-muted hover:text-primary transition-colors text-sm font-medium">Community</a></li>
        <li><a href="#recruitment" class="text-muted hover:text-primary transition-colors text-sm font-medium">Recruitment</a></li>
        <li><a href="#contact" class="text-muted hover:text-primary transition-colors text-sm font-medium">Contact</a></li>
      </ul>

      <!-- CTA + Mobile Menu -->
      <div class="flex items-center gap-4">
        <a href="#report" class="hidden sm:inline-flex items-center gap-2 bg-accent hover:bg-accent/90 text-base font-semibold px-5 py-2.5 rounded-lg transition-all hover:shadow-lg hover:shadow-accent/20">
          <!-- Fingerprint icon -->
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 11c0 3.5-1 6.5-3 9M12 11c0-1.5-.5-3-2-4s-3.5-1-5 0M12 11c0-1.5.5-3 2-4s3.5-1 5 0M7 17c0 2 .5 3.5 1.5 5M17 17c0 2-.5 3.5-1.5 5M12 2v2M12 6c-3.5 0-6 2.5-6 5M12 6c3.5 0 6 2.5 6 5"/>
          </svg>
          File a Report
        </a>
        
        <!-- Mobile Menu Button -->
        <button class="lg:hidden p-2 text-muted hover:text-primary transition-colors" aria-label="Open menu" id="mobile-menu-btn">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden bg-surface-dark border-t border-border">
      <ul class="px-4 py-6 space-y-4">
        <li><a href="#about" class="block text-muted hover:text-primary transition-colors font-medium">About</a></li>
        <li><a href="#services" class="block text-muted hover:text-primary transition-colors font-medium">Services</a></li>
        <li><a href="#transparency" class="block text-muted hover:text-primary transition-colors font-medium">Transparency</a></li>
        <li><a href="#community" class="block text-muted hover:text-primary transition-colors font-medium">Community</a></li>
        <li><a href="#recruitment" class="block text-muted hover:text-primary transition-colors font-medium">Recruitment</a></li>
        <li><a href="#contact" class="block text-muted hover:text-primary transition-colors font-medium">Contact</a></li>
        <li class="pt-4">
          <a href="#report" class="inline-flex items-center gap-2 bg-accent text-base font-semibold px-5 py-2.5 rounded-lg">
            File a Report
          </a>
        </li>
      </ul>
    </div>
  </header>

  <main>
    <!-- HERO SECTION -->
    <section class="relative min-h-screen flex items-center overflow-hidden" id="about">
      <!-- Video Background -->
      <div class="absolute inset-0">
        <video 
          autoplay 
          muted 
          loop 
          playsinline 
          poster="/hero-poster.jpg"
          class="w-full h-full object-cover"
        >
          <source src="/hero.mp4" type="video/mp4" />
        </video>
        <div class="absolute inset-0 bg-base/75"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 lg:py-40">
        <div class="max-w-3xl">
          <!-- Eyebrow -->
          <p class="font-mono text-accent text-sm tracking-[0.3em] mb-6">
            EST. 1847 • 14 TOWNS • 487 SQUARE MILES
          </p>
          
          <!-- Headline -->
          <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl text-primary leading-none mb-6">
            SERVING GRANITE<br/>RIDGE COUNTY
          </h1>
          
          <!-- Subhead -->
          <p class="text-lg sm:text-xl text-muted max-w-2xl mb-10 leading-relaxed">
            A modern sheriff's office committed to transparency, community, and the safety of every resident across New Hampshire's North Country.
          </p>
          
          <!-- CTAs -->
          <div class="flex flex-wrap gap-4">
            <a href="#dashboard" class="inline-flex items-center gap-2 bg-accent hover:bg-accent/90 text-base font-semibold px-6 py-3 rounded-lg transition-all hover:shadow-xl hover:shadow-accent/20">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="3" y="3" width="7" height="7" rx="1"/>
                <rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/>
                <rect x="14" y="14" width="7" height="7" rx="1"/>
              </svg>
              View Public Dashboard
            </a>
            <a href="#tip" class="inline-flex items-center gap-2 border-2 border-muted hover:border-primary text-primary font-semibold px-6 py-3 rounded-lg transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M12 19V5M5 12l7-7 7 7"/>
              </svg>
              Submit a Tip
            </a>
          </div>
        </div>
      </div>

      <!-- Live Status Indicator -->
      <div class="absolute bottom-8 right-8 hidden md:flex items-center gap-3 bg-surface-dark/80 backdrop-blur-sm border border-border rounded-lg px-4 py-3">
        <span class="relative flex h-3 w-3">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
          <span class="relative inline-flex rounded-full h-3 w-3 bg-success"></span>
        </span>
        <div>
          <p class="text-sm font-semibold text-primary">LIVE</p>
          <p class="text-xs text-muted">All Systems Operational</p>
        </div>
      </div>

      <!-- Scroll Indicator (centered, clean stacking) -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-2 text-primary/70">
        <span class="text-xs tracking-[0.3em] font-mono">SCROLL</span>
        <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </div>
    </section>

    <!-- LIVE TRANSPARENCY DASHBOARD -->
    <section class="bg-surface-dark py-20 lg:py-28 relative overflow-hidden" id="dashboard">
      <!-- Background accent -->
      <div class="absolute top-0 right-0 w-1/2 h-1/2 bg-gradient-radial from-accent/5 to-transparent" aria-hidden="true"></div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <!-- Section Header -->
        <div class="text-center max-w-2xl mx-auto mb-16">
          <p class="font-mono text-accent text-sm tracking-[0.3em] mb-4">PUBLIC DATA</p>
          <h2 class="font-display text-4xl sm:text-5xl text-primary mb-6">TRANSPARENCY IN REAL TIME</h2>
          <p class="text-muted leading-relaxed">
            We believe public trust is built through openness. Our live dashboard gives you direct access to the metrics that matter—updated continuously, accessible to everyone.
          </p>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
          <!-- Stat 1: Calls This Year -->
          <div class="bg-surface-mid border border-border rounded-xl p-6 hover:border-accent/50 transition-colors">
            <div class="flex items-center justify-between mb-4">
              <span class="text-muted text-sm font-medium">Calls This Year</span>
              <span class="flex items-center gap-1 text-success text-xs font-mono">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M5 15l7-7 7 7"/>
                </svg>
                +3.2%
              </span>
            </div>
            <p class="font-mono text-4xl text-primary font-semibold">12,847</p>
          </div>

          <!-- Stat 2: Avg Response Time -->
          <div class="bg-surface-mid border border-border rounded-xl p-6 hover:border-accent/50 transition-colors">
            <div class="flex items-center justify-between mb-4">
              <span class="text-muted text-sm font-medium">Avg Response Time</span>
              <span class="flex items-center gap-1 text-success text-xs font-mono">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M19 9l-7 7-7-7"/>
                </svg>
                -0:18
              </span>
            </div>
            <p class="font-mono text-4xl text-primary font-semibold">6:42</p>
            <p class="text-xs text-muted mt-1">minutes</p>
          </div>

          <!-- Stat 3: Cases Cleared -->
          <div class="bg-surface-mid border border-border rounded-xl p-6 hover:border-accent/50 transition-colors">
            <div class="flex items-center justify-between mb-4">
              <span class="text-muted text-sm font-medium">Cases Cleared</span>
            </div>
            <div class="flex items-center gap-4">
              <p class="font-mono text-4xl text-primary font-semibold">78%</p>
              <!-- Progress Ring -->
              <svg class="w-14 h-14" viewBox="0 0 48 48" aria-hidden="true">
                <circle cx="24" cy="24" r="20" fill="none" stroke="#1e3a8a" stroke-width="4"/>
                <circle cx="24" cy="24" r="20" fill="none" stroke="#60a5fa" stroke-width="4" 
                  stroke-dasharray="125.6" stroke-dashoffset="27.6" 
                  stroke-linecap="round" transform="rotate(-90 24 24)"/>
              </svg>
            </div>
          </div>

          <!-- Stat 4: Officers on Duty -->
          <div class="bg-surface-mid border border-border rounded-xl p-6 hover:border-accent/50 transition-colors">
            <div class="flex items-center justify-between mb-4">
              <span class="text-muted text-sm font-medium">Officers on Duty Now</span>
              <span class="relative flex h-2.5 w-2.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-success"></span>
              </span>
            </div>
            <p class="font-mono text-4xl text-primary font-semibold">23</p>
            <p class="text-xs text-muted mt-1">active patrol units</p>
          </div>
        </div>

        <!-- Horizontal Bar Chart: Calls by Type -->
        <div class="bg-surface-mid border border-border rounded-xl p-6 lg:p-8">
          <h3 class="text-lg font-semibold text-primary mb-6">Calls by Type — Year to Date</h3>
          <div class="space-y-4">
            <!-- Welfare Checks -->
            <div class="flex items-center gap-4">
              <span class="w-28 text-sm text-muted shrink-0">Welfare Checks</span>
              <div class="flex-1 h-8 bg-base rounded overflow-hidden">
                <div class="h-full bg-accent rounded" style="width: 85%"></div>
              </div>
              <span class="font-mono text-sm text-primary w-16 text-right">3,241</span>
            </div>
            <!-- Traffic -->
            <div class="flex items-center gap-4">
              <span class="w-28 text-sm text-muted shrink-0">Traffic</span>
              <div class="flex-1 h-8 bg-base rounded overflow-hidden">
                <div class="h-full bg-blue-500 rounded" style="width: 72%"></div>
              </div>
              <span class="font-mono text-sm text-primary w-16 text-right">2,876</span>
            </div>
            <!-- Domestic -->
            <div class="flex items-center gap-4">
              <span class="w-28 text-sm text-muted shrink-0">Domestic</span>
              <div class="flex-1 h-8 bg-base rounded overflow-hidden">
                <div class="h-full bg-blue-600 rounded" style="width: 48%"></div>
              </div>
              <span class="font-mono text-sm text-primary w-16 text-right">1,892</span>
            </div>
            <!-- Property -->
            <div class="flex items-center gap-4">
              <span class="w-28 text-sm text-muted shrink-0">Property</span>
              <div class="flex-1 h-8 bg-base rounded overflow-hidden">
                <div class="h-full bg-blue-700 rounded" style="width: 56%"></div>
              </div>
              <span class="font-mono text-sm text-primary w-16 text-right">2,214</span>
            </div>
            <!-- Other -->
            <div class="flex items-center gap-4">
              <span class="w-28 text-sm text-muted shrink-0">Other</span>
              <div class="flex-1 h-8 bg-base rounded overflow-hidden">
                <div class="h-full bg-blue-800 rounded" style="width: 65%"></div>
              </div>
              <span class="font-mono text-sm text-primary w-16 text-right">2,624</span>
            </div>
          </div>
        </div>

        <!-- Updated timestamp -->
        <div class="flex items-center justify-center gap-2 mt-8 text-muted text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          <span>Updated 2 minutes ago</span>
        </div>
      </div>
    </section>

    <!-- SERVICES GRID -->
    <section class="bg-base py-20 lg:py-28" id="services">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center max-w-2xl mx-auto mb-16">
          <p class="font-mono text-accent text-sm tracking-[0.3em] mb-4">WHAT WE DO</p>
          <h2 class="font-display text-4xl sm:text-5xl text-primary mb-6">SERVICES FOR EVERY RESIDENT</h2>
        </div>

        <!-- Services Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Patrol & Response -->
          <div class="group bg-surface-dark border border-border rounded-xl p-6 hover:border-accent transition-colors">
            <div class="w-12 h-12 bg-surface-mid rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent/10 transition-colors">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-primary mb-2">Patrol & Response</h3>
            <p class="text-muted leading-relaxed">24/7 coverage across all 14 towns with rapid response times. Our deputies know every back road, trail, and community in Granite Ridge County.</p>
          </div>

          <!-- Investigations -->
          <div class="group bg-surface-dark border border-border rounded-xl p-6 hover:border-accent transition-colors">
            <div class="w-12 h-12 bg-surface-mid rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent/10 transition-colors">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/>
                <path d="M21 21l-4.35-4.35"/>
                <path d="M11 8v6M8 11h6"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-primary mb-2">Investigations</h3>
            <p class="text-muted leading-relaxed">Dedicated detective unit handling major crimes, fraud, and cold cases. We leverage modern forensics and inter-agency partnerships to solve cases.</p>
          </div>

          <!-- Court Security -->
          <div class="group bg-surface-dark border border-border rounded-xl p-6 hover:border-accent transition-colors">
            <div class="w-12 h-12 bg-surface-mid rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent/10 transition-colors">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M3 21h18M5 21V7l8-4 8 4v14M9 21v-6h6v6"/>
                <rect x="9" y="9" width="2" height="2"/>
                <rect x="13" y="9" width="2" height="2"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-primary mb-2">Court Security</h3>
            <p class="text-muted leading-relaxed">Ensuring the safety of judicial proceedings at Granite Ridge Superior Court. Our bailiffs maintain order and protect all participants.</p>
          </div>

          <!-- Civil Process Service -->
          <div class="group bg-surface-dark border border-border rounded-xl p-6 hover:border-accent transition-colors">
            <div class="w-12 h-12 bg-surface-mid rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent/10 transition-colors">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M9 12h6M9 16h6M17 21H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-primary mb-2">Civil Process Service</h3>
            <p class="text-muted leading-relaxed">Professional, timely delivery of legal documents including subpoenas, summons, and court orders throughout the county.</p>
          </div>

          <!-- School Resource Officers -->
          <div class="group bg-surface-dark border border-border rounded-xl p-6 hover:border-accent transition-colors">
            <div class="w-12 h-12 bg-surface-mid rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent/10 transition-colors">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M12 14l9-5-9-5-9 5 9 5z"/>
                <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                <path d="M12 14v7"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-primary mb-2">School Resource Officers</h3>
            <p class="text-muted leading-relaxed">Deputies assigned to local schools building relationships with students, conducting safety drills, and providing mentorship.</p>
          </div>

          <!-- Community Outreach -->
          <div class="group bg-surface-dark border border-border rounded-xl p-6 hover:border-accent transition-colors">
            <div class="w-12 h-12 bg-surface-mid rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent/10 transition-colors">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-primary mb-2">Community Outreach</h3>
            <p class="text-muted leading-relaxed">Programs designed to build trust and connection: Coffee with a Cop, Citizens Academy, youth mentoring, and senior wellness visits.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TRANSPARENCY & RECORDS -->
    <section class="bg-gradient-to-b from-base to-surface-dark py-20 lg:py-28" id="transparency">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 items-center">
          <!-- Left Content (3 cols) -->
          <div class="lg:col-span-3">
            <p class="font-mono text-accent text-sm tracking-[0.3em] mb-4">ACCOUNTABILITY</p>
            <h2 class="font-display text-4xl sm:text-5xl text-primary mb-6">PUBLIC RECORDS & ACCOUNTABILITY</h2>
            <p class="text-muted leading-relaxed mb-8">
              We believe every resident has the right to understand how their sheriff's office operates. Under Sheriff Marcus Whitfield's leadership, we've made transparency a core pillar of our department. All records requests are processed within 5 business days.
            </p>
            <ul class="space-y-4 mb-8">
